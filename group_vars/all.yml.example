---
# =============================================================================
# Versions
# =============================================================================
singbox_version: "1.13.7"

common_disable_ipv6: true
common_manage_unattended_upgrades: false

singbox_arch_map:
  x86_64: amd64
  amd64: amd64
  aarch64: arm64
  arm64: arm64

# =============================================================================
# DE -> sing-box server (chain only, locked to RU IP via firewall)
# =============================================================================
singbox_server_port: 4433
singbox_server_method: "2022-blake3-aes-256-gcm"
singbox_server_password: "REPLACE_ME_BASE64_32_BYTES"
singbox_server_listen: "0.0.0.0"
singbox_server_multiplex: true

# --- Router (Flint 2) SS-2022 inbound on edge ---
router_ss_port: 8388
router_ss_method: "2022-blake3-aes-256-gcm"
router_ss_secret: ""   # openssl rand -base64 32 — НЕ переиспользуй secret цепочки :4433

# --- Router DNS / отказоустойчивость ---
# RU DNS over TLS: анти-спуфинг для заблокированных доменов (instagram/discord/...).
# Plain UDP:53 РКН подделывает на пути → desync получал бы отравленный IP.
ru_dns_dot_ip:  "77.88.8.8"
ru_dns_dot_sni: "common.dot.dns.yandex.net"
# Cron-watchdog (раз в минуту) поднимает sing-box при падении процесса.
# Мягкая замена жёсткого kill-switch: тоннель-down переживается сам, без утечки.
router_singbox_watchdog: true

# =============================================================================
# Транспорт leg home→edge (роутер Flint 2 → edge VPS)
# =============================================================================
# Почему не «голый» SS-2022 (router-in :8388): ТСПУ провайдера ушёл от сигнатур
# протокола к АНАЛИЗУ ПОВЕДЕНИЯ + JA3/JA4. SS2022 палится первым же шифроблоком
# (TCP-handshake проходит, payload дропается → «чёрная дыра»). Два новых
# транспорта на edge всегда включены параллельно, активный на роутере выбирается
# переменной router_primary_transport (см. ниже) — переключение = смена
# переменной + редеплой ТОЛЬКО роутера, edge держит оба inbound постоянно.
#
#  1) hysteria2 (primary) — UDP/QUIC. TCP-ориентированный ТСПУ его не видит как
#     поток для DPI-разбора; TLS поверх QUIC использует УЖЕ существующий LE-серт
#     edge (тот же fullchain, что у nginx/mtg) → валидный серт на IP-коннекте.
#     obfs salamander подмешивает соль в QUIC-initial, пряча сигнатуру QUIC.
#  2) shadowtls v3 (fallback) — TCP. Маскируется под TLS1.3-хендшейк к реальному
#     популярному сайту (handshake_server), затем туннелирует внутренний SS2022.
#     Нужен, если провайдер режет UDP/QUIC целиком.
#
# ВАЖНО — Brutal ВЫКЛЮЧЕН СОЗНАТЕЛЬНО: up_mbps/down_mbps НЕ задаются ни на edge,
# ни на роутере. На стабильном канале Brutal (BBR-подобный CC с фиксированной
# полосой) генерит аномально ровный трафик-паттерн → отдельный признак для
# поведенческого детекта. Оставляем штатный congestion control.

# --- hysteria2 (primary). UDP-порт без коллизий с 22/80/443/1080/1081/2080/
#     2081/4433/8388/8443/9443/56000/56001 и НЕ 443 (там ocserv udp на DE,
#     на edge — mtg). Если провайдер режет этот UDP-порт/QUIC — сменить на другой
#     высокий UDP-порт и редеплой edge+роутер (см. README, шаг (f)). ---
hy2_port: 39443
hy2_password: "REPLACE_ME_BASE64_32_BYTES"       # openssl rand -base64 32
hy2_obfs_password: "REPLACE_ME_BASE64_32_BYTES"  # openssl rand -base64 32

# --- shadowtls v3 (fallback). TCP-порт без коллизий (см. список выше). ---
shadowtls_port: 8843
shadowtls_password: "REPLACE_ME_BASE64_32_BYTES" # openssl rand -base64 32
# Реальный TLS1.3-домен для маскировки хендшейка. Общий для edge-inbound
# (handshake.server) и router-outbound (tls.server_name). Дефолт — нейтральный
# популярный TLS1.3-сайт. При whitelist-режиме ТСПУ («белый список») можно
# заменить на whitelisted RU-домен, разрешённый к доступу с RU IP.
shadowtls_handshake_server: "www.microsoft.com"
# Внутренний SS2022 под shadowtls (detour-цель на edge / detour-источник на
# роутере). НОВЫЙ ключ — НЕ переиспользуй router_ss_secret и не secret цепочки :4433.
shadowtls_ss_method: "2022-blake3-aes-256-gcm"
shadowtls_ss_secret: "REPLACE_ME_BASE64_32_BYTES"  # openssl rand -base64 32

# Активный транспорт на РОУТЕРЕ: hysteria2 (primary) | shadowtls (fallback).
# Edge ВСЕГДА слушает оба inbound (hy2-in + shadowtls-in), поэтому переключение —
# смена этой переменной + редеплой ТОЛЬКО роутера (edge не трогаем). owrt_singbox
# рендерит соответствующий outbound (тег proxy); любое другое значение валит
# assert. Держим hysteria2, пока QUIC/UDP не режут; на shadowtls переходим, если
# провайдер срежет UDP целиком.
router_primary_transport: hysteria2

# =============================================================================
# Транспорт leg edge→DE (edge VPS → DE gateway) — ОДИН ТРАНСПОРТ
# =============================================================================
# Единственное звено, реально пересекающее границу. Раньше тут была urltest-
# группа "de-out" из трёх кандидатов (hysteria2 + shadowtls + legacy ss). Это
# схлопнуто до ОДНОГО транспорта по двум причинам:
#   1) трансграничный RU→DE QUIC режется сильнее, чем TCP — hysteria2 здесь
#      нестабилен, а от единственной реальной угрозы плеча (блок Fornex по IP/ASN)
#      UDP всё равно не страхует; TCP предсказуемее. hysteria2 edge→DE убран;
#   2) urltest health-check ходил через remote-dns, а remote-dns детурил в саму
#      urltest-группу → циклическая зависимость, дававшая периодические обрывы.
# Активный транспорт выбирается переменной de_uplink_transport (как
# router_primary_transport на роутере). DE слушает shadowtls-in + legacy ss-in
# ПОСТОЯННО, поэтому переключение = смена переменной + редеплой только edge.
#
# Brutal так же ВЫКЛЮЧЕН (нет up_mbps/down_mbps) — ровный трафик-паттерн палит.
#
# ВАЖНО: продублируй эти значения в реальный (gitignored) group_vars/all.yml.
# Все *_password / *_secret ниже — НОВЫЕ ключи (openssl rand -base64 32), НЕ
# переиспользуй ключи других ног (singbox_server_password, hy2_password,
# shadowtls_*_secret, router_ss_secret и т.п.). shadowtls/ss-in на DE сертов не
# требуют (shadowtls маскируется под внешний handshake-сервер, ss-in безсертовый).

# Активный транспорт плеча edge→DE: shadowtls (default) | ss.
#   shadowtls → outbound de-shadowtls-ss (TCP, маскировка под TLS1.3)
#   ss        → outbound de-ss (голый legacy SS2022 :4433, ручной fallback)
# DE держит оба inbound всегда; смена значения + редеплой edge переключает плечо.
de_uplink_transport: shadowtls

# --- shadowtls v3 (активный по умолчанию). TCP-порт на DE без коллизий с занятыми
#     22/80/443/853/1080/1081/2080/2081/4433/8388/8843/39443/56000/56001.
#     8943 свободен; занят — подбери другой свободный TCP. ---
de_shadowtls_port: 8943
de_shadowtls_password: "REPLACE_ME_BASE64_32_BYTES" # openssl rand -base64 32, НОВЫЙ
# Реальный TLS1.3-домен для маскировки shadowtls-хендшейка (общий для DE-inbound
# handshake.server и edge-outbound tls.server_name). Популярный TLS1.3-сайт.
de_shadowtls_handshake_server: "www.microsoft.com"
# Внутренний SS2022 под shadowtls (detour-цель на DE / detour-источник на edge).
# НОВЫЙ ключ — НЕ переиспользуй shadowtls_ss_secret (router-нога) и не secret :4433.
de_shadowtls_ss_method: "2022-blake3-aes-256-gcm"
de_shadowtls_ss_secret: "REPLACE_ME_BASE64_32_BYTES"  # openssl rand -base64 32, НОВЫЙ

# =============================================================================
# RU -> sing-box client (relays everything to DE)
# =============================================================================
ru_singbox_socks_bind: "127.0.0.1"
ru_singbox_socks_port: 1081
ru_singbox_http_bind: "127.0.0.1"
ru_singbox_http_port: 1080
ru_singbox_default_interface: "auto"

# =============================================================================
# Public browser proxy on RU (SOCKS5/HTTP with auth)
# Expose externally for FoxyProxy etc.
# =============================================================================
ru_public_proxy_enable: true
ru_public_proxy_bind: "0.0.0.0"
ru_public_proxy_socks_port: 2081
ru_public_proxy_http_port: 2080

# =============================================================================
# OpenConnect / ocserv on DE (full-tunnel VPN)
# =============================================================================
ocserv_domain: "vpn.example.net"
ocserv_acme_email: "admin@example.net"

ocserv_tls_priorities: "NORMAL:%SERVER_PRECEDENCE:%COMPAT:-RSA:-VERS-SSL3.0:-ARCFOUR-128:-VERS-TLS1.0:-VERS-TLS1.1"

ocserv_listen_tcp_port: 443
ocserv_listen_udp_port: 443

ocserv_vpn_network: "10.99.0.0"
ocserv_vpn_netmask: "255.255.255.0"
ocserv_vpn_prefix: 24
ocserv_vpn_gateway: "10.99.0.1"

ocserv_max_clients: 32
ocserv_max_same_clients: 4

# =============================================================================
# Unified users list — used for BOTH browser proxy on RU AND ocserv VPN on DE.
# Each user gets ONE password used in both places.
# Generate passwords with:
#   for u in alice wife friend1; do
#     printf '  - name: %s\n    password: "%s"\n' "$u" \
#       "$(LC_ALL=C tr -dc 'A-Za-z0-9' </dev/urandom | head -c 24)"
#   done
# =============================================================================
vpn_users:
  - name: alice
    password: "REPLACE_ME"
  # - name: wife
  #   password: "REPLACE_ME"

# Aliases for clarity in templates (point to the same list)
proxy_users: "{{ vpn_users }}"

# =============================================================================
# WDTT — WireGuard over TURN Tunnel (Android → VK TURN servers → DE VPS)
# Клиент: https://github.com/amurcanov/proxy-turn-vk-android
# Порт 56000/udp открыт публично; 56001/udp — внутренний WireGuard.
# =============================================================================
wdtt_dtls_port: 56000
wdtt_wg_port: 56001
wdtt_config_dir: /etc/wdtt
# Мастер-пароль для первого пользователя (владельца). Сгенерировать:
#   LC_ALL=C tr -dc 'A-Za-z0-9_@%+=:.,-' </dev/urandom | head -c 32; echo
wdtt_password: "REPLACE_ME_MASTER_PASSWORD"
# Опционально: Telegram-бот для управления паролями пользователей
wdtt_telegram_admin: ""   # ID пользователя Telegram (числовой)
wdtt_telegram_bot_token: ""
# Версия тега из https://github.com/amurcanov/proxy-turn-vk-android/releases
wdtt_version: "v1.2.2"
# Версия Go для сборки; должна соответствовать go.mod (>= 1.25.0)
wdtt_go_version: "1.25.0"

# =============================================================================
# SSH
# =============================================================================
ssh_port: 22

# =============================================================================
# DPI bypass — nfqws, прямой WAN + десинк для РКН-заблокированных с RU IP
# =============================================================================
# MediaTek HW offload обходит netfilter, поэтому NFQUEUE его не видит.
# owrt_disable_hw_offload: true отключает hw offload на роутере (sw остаётся).
# На 500 Мбит/с при низкой нагрузке потеря скорости некритична.
owrt_disable_hw_offload: true

# Домены, которые обходят РКН локально (прямой WAN + nfqws-десинк, БЕЗ тоннеля).
# Всё, чего тут НЕТ и что не RU (geosite-ru/geoip-ru) → уходит в тоннель (final: proxy).
#
# ВАЖНО про резолв через dns-local (Yandex DoT, detour: direct):
# Yandex запрашивается с RU IP роутера и по требованию РКН отдаёт NXDOMAIN на
# домены Meta (instagram/facebook/cdninstagram/fbcdn) — DoT тут не спасает, это
# политика самого резолвера, а не спуфинг на пути. Поэтому Meta-домены НЕЛЬЗЯ
# оставлять в этом списке с резолвом через Yandex: либо убрать в тоннель (ниже),
# либо резолвить через dns-remote.
#
# Пусто (dpi_bypass_domains: []) → ВСЕ заблокированные сайты идут через тоннель
# (gateway). Надёжно (мимо nfqws/TSPU и мимо Yandex-цензуры), но youtube грузит
# bandwidth тоннеля и выходит с DE IP. Шаблон owrt_singbox корректно генерит
# конфиг и для пустого списка (правила dpi-bypass просто не добавляются).
dpi_bypass_domains: []
# Вариант nfqws-direct (нужен рабочий nfqws + Meta резолвить мимо Yandex):
#   - youtube.com
#   - googlevideo.com
#   - ytimg.com
#   - ggpht.com
#   - x.com
#   - twitter.com
#   - t.co
#   - twimg.com

# Метка сокета (SO_MARK) для трафика dpi-bypass-direct outbound в sing-box.
# nftables перехватывает пакеты с этой меткой в OUTPUT → NFQUEUE → nfqws.
nfqws_routing_mark: 100
nfqws_queue_num: 1

# fwmark, которым nfqws метит СВОИ инжектируемые десинк-пакеты (опция nfqws
# --dpi-desync-fwmark, это её дефолт). dpi-bypass.sh по этой метке добавляет
# ip rule (pref 8000 → main table), чтобы raw-пакеты nfqws уходили в WAN напрямую,
# а не утягивались auto_route sing-box в тоннель (иначе "sendto: Operation not
# permitted"). Если переопределяешь --dpi-desync-fwmark в nfqws_args — синхронизируй тут.
nfqws_fwmark: "0x40000000"

# Домены, которым достаётся УСИЛЕННАЯ стратегия nfqws (первый профиль, до --new).
# googlevideo РФ TSPU режет агрессивнее обычного split — нужен fake-пакет + md5sig,
# иначе страница youtube.com грузится, а видео из googlevideo.com встаёт.
# ВАЖНО: должны быть подмножеством dpi_bypass_domains, иначе sing-box не пометит
# их mark'ом nfqws_routing_mark (100) и nftables не отдаст пакеты в очередь nfqws.
nfqws_youtube_domains:
  - youtube.com
  - googlevideo.com
  - ytimg.com
  - ggpht.com

# Аргументы nfqws — два профиля, разделённые --new (per-host split):
#   1) hostlist youtube/googlevideo → fake,multidisorder + md5sig (сильная стратегия)
#   2) catch-all (instagram/facebook/x/twitter) → обычный multidisorder split
# nfqws применяет ПЕРВЫЙ профиль, чей фильтр совпал по SNI; профиль 2 без hostlist
# ловит то, что не попало в hostlist профиля 1. nftables и так отдаёт в очередь
# только mark=100 (= dpi_bypass_domains), поэтому профиль 2 не трогает обычный трафик.
# {{ ... }} ниже разворачивает Ansible при загрузке переменных (это vars-файл, а не
# шаблон) — в итоговую строку подставится список доменов через запятую.
# Стратегии подбирать под свой TSPU (blockcheck.sh из ПОЛНОГО релиза zapret, а не
# одним файлом — иначе ошибка common/base.sh).
# Если профиль 1 не помог по youtube — пробуй fake,multisplit + seqovl или badseq.
nfqws_args: >-
  --filter-tcp=443
  --hostlist-domains={{ nfqws_youtube_domains | join(',') }}
  --dpi-desync=fake,multidisorder
  --dpi-desync-split-pos=midsld
  --dpi-desync-fooling=md5sig
  --new
  --filter-tcp=443
  --dpi-desync=multidisorder
  --dpi-desync-split-pos=1,midsld,host+1,sld+2

# Версия zapret (bol-van/zapret) для скачивания бинаря nfqws.
# URL: https://github.com/bol-van/zapret/releases/download/v{{ nfqws_version }}/zapret-v{{ nfqws_version }}.tar.gz
# Проверь актуальный тег: https://github.com/bol-van/zapret/releases
nfqws_version: "72.1"

# =============================================================================
# Reverse SSH management tunnel (de_mgmt + owrt_mgmt)
# =============================================================================
# Роутер за CGNAT/ТСПУ недостижим снаружи → ОН сам держит `ssh -R` к гейтвею
# ЧЕРЕЗ существующий sing-box-тоннель (dst = заграничный IP гейтвея → proxy/hy2,
# ТСПУ видит лишь QUIC). С гейтвея потом:
#   ssh -p {{ mgmt_reverse_port }} root@127.0.0.1   → попадаешь на роутер.
# Ключевая пара генерится на control node в ./secrets/ (gitignore) при деплое;
# приватный ключ заливается на роутер, публичный — в authorized_keys {{ mgmt_user }}.
# У всех переменных есть дефолты в ролях — раскомментируй только для переопределения.
# mgmt_user: rtun
# mgmt_reverse_port: 2222
# mgmt_ssh_key: "{{ playbook_dir }}/secrets/rtun_ed25519"
