{%- set dpi_bypass_json = dpi_bypass_domains | to_json -%}
{
  "log": { "level": "warn", "timestamp": true },
  "experimental": {
    "cache_file": { "enabled": true, "path": "/etc/sing-box/cache.db" }
  },
  "dns": {
    "servers": [
      { "type": "https", "tag": "dns-remote", "server": "1.1.1.1", "detour": "proxy" },
      { "type": "tls",   "tag": "dns-local",  "server": "{{ ru_dns_dot_ip }}", "server_port": 853, "tls": { "enabled": true, "server_name": "{{ ru_dns_dot_sni }}" } }
    ],
    "rules": [
{% if dpi_bypass_domains %}
      { "domain_suffix": {{ dpi_bypass_json }}, "server": "dns-local" },
{% endif %}
      { "rule_set": "geosite-ru", "server": "dns-local" },
      { "domain_suffix": [".ru"], "server": "dns-local" }
    ],
    "final": "dns-remote",
    "strategy": "ipv4_only",
    "independent_cache": true
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "interface_name": "singtun0",
      "address": ["172.19.0.1/30"],
      "auto_route": true,
      "strict_route": true,
      "stack": "system"
    }
  ],
  "outbounds": [
{#
  Тег "proxy" (на него указывает route.final) — leg home->edge. Активный
  транспорт выбирается router_primary_transport (ручной переключатель, по образцу
  de_uplink_transport на edge); edge всегда слушает оба inbound (hy2-in +
  shadowtls-in), переключение = смена переменной + редеплой только роутера. См.
  assert в tasks/main.yml (единый источник допустимых значений).
    hysteria2 (primary): UDP/QUIC + obfs salamander — TCP-ориентированный ТСПУ не
  видит поток для DPI-разбора. TLS поверх QUIC валидирует УЖЕ существующий LE-серт
  edge (server_name = {{ domain }}). Brutal ВЫКЛЮЧЕН сознательно: up/down mbps не
  задаём (ровный паттерн → поведенческий детект).
    shadowtls (fallback): TCP — shadowtls v3 маскирует TLS1.3-handshake под
  {{ shadowtls_handshake_server }}, внутри SS2022 (метод/secret shadowtls_ss_*).
  На случай, если ТСПУ срежет QUIC/UDP. multiplex НЕ включаем: edge-инбаунд
  shadowtls-ss-in идёт без mux — рвать симметрию нельзя (blackhole обратного
  канала, как было на DE).
  Legacy router-in (:8388 SS) на edge остаётся, как outbound не нужен.
#}
{% if router_primary_transport == 'hysteria2' %}
    {
      "type": "hysteria2",
      "tag": "proxy",
      "server": "{{ _edge_vps_ip }}",
      "server_port": {{ hy2_port }},
      "password": "{{ hy2_password }}",
      "obfs": {
        "type": "salamander",
        "password": "{{ hy2_obfs_password }}"
      },
      "tls": {
        "enabled": true,
        "server_name": "{{ domain }}",
        "alpn": ["h3"]
      }
    },
{% else %}
    {
      "type": "shadowtls",
      "tag": "proxy-stls",
      "server": "{{ _edge_vps_ip }}",
      "server_port": {{ shadowtls_port }},
      "version": 3,
      "password": "{{ shadowtls_password }}",
      "tls": {
        "enabled": true,
        "server_name": "{{ shadowtls_handshake_server }}"
      }
    },
    {
      "type": "shadowsocks",
      "tag": "proxy",
      "method": "{{ shadowtls_ss_method }}",
      "password": "{{ shadowtls_ss_secret }}",
      "detour": "proxy-stls"
    },
{% endif %}
    { "type": "direct", "tag": "direct" },
    { "type": "block",  "tag": "block" },
    {
      "type": "direct",
      "tag": "dpi-bypass-direct",
      "routing_mark": {{ nfqws_routing_mark }}
    }
  ],
  "route": {
    "rules": [
      { "action": "sniff" },
      { "protocol": "dns", "action": "hijack-dns" },
      { "ip_is_private": true, "outbound": "direct" },
{% if dpi_bypass_domains %}
      { "domain_suffix": {{ dpi_bypass_json }}, "network": "udp", "port": 443, "outbound": "block" },
      { "domain_suffix": {{ dpi_bypass_json }}, "outbound": "dpi-bypass-direct" },
{% endif %}
      { "rule_set": ["geosite-ru", "geoip-ru"], "outbound": "direct" }
    ],
    "rule_set": [
{# Локальные .srs (залиты Ansible). НЕ remote+download_detour:proxy — иначе старт
   sing-box висит на живом туннеле и при мёртвом proxy валится в FATAL → утечка. #}
{% for rs in owrt_rule_sets %}
      { "type": "local", "tag": "{{ rs.tag }}", "format": "binary", "path": "{{ owrt_ruleset_dir }}/{{ rs.tag }}.srs" }{{ "," if not loop.last else "" }}
{% endfor %}
    ],
    "final": "proxy",
    "default_domain_resolver": { "server": "dns-local", "strategy": "ipv4_only" },
    "auto_detect_interface": true
  }
}
