server {
    listen 127.0.0.1:8443 ssl http2;
    server_name {{ tgproxy_domain }};

    ssl_certificate     /etc/letsencrypt/live/{{ tgproxy_domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ tgproxy_domain }}/privkey.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;

    location / {
        proxy_pass          https://127.0.0.1:{{ tgproxy_gost_port }};
        proxy_ssl_server_name on;
        proxy_ssl_name      api.telegram.org;
        proxy_ssl_verify    off;
        proxy_http_version  1.1;
        proxy_set_header    Host api.telegram.org;
        proxy_set_header    Connection "";
        proxy_connect_timeout 10s;
        proxy_read_timeout  30s;
        proxy_send_timeout  10s;
    }
}
