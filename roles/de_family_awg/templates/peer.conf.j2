# AmneziaWG 2.0 client config for {{ item.name }} — import on the Keenetic.
# ASC params MUST match the server (shared per-interface). Endpoint/keys/PSK are
# this peer's; do not share this file. Generated by de_family_awg.
[Interface]
PrivateKey = {{ awg_family_peer_secrets[item.name].private_key }}
Address = {{ item.ip }}/32
DNS = {{ awg_family_server_ip }}
Jc = {{ awg_family_asc.jc }}
Jmin = {{ awg_family_asc.jmin }}
Jmax = {{ awg_family_asc.jmax }}
S1 = {{ awg_family_asc.s1 }}
S2 = {{ awg_family_asc.s2 }}
S3 = {{ awg_family_asc.s3 }}
S4 = {{ awg_family_asc.s4 }}
H1 = {{ awg_family_asc.h1 }}
H2 = {{ awg_family_asc.h2 }}
H3 = {{ awg_family_asc.h3 }}
H4 = {{ awg_family_asc.h4 }}
I1 = {{ awg_family_asc.i1 }}

[Peer]
PublicKey = {{ awg_family_server_public_key }}
PresharedKey = {{ awg_family_peer_secrets[item.name].preshared_key }}
AllowedIPs = 0.0.0.0/0
Endpoint = {{ awg_family_endpoint_host }}:{{ awg_family_port }}
PersistentKeepalive = 25
