{%- set de_active = 'de-ss' if (de_uplink_transport | default('shadowtls')) == 'ss' else 'de-shadowtls-ss' -%}
{
  "log": {
    "disabled": false,
    "level": "info",
    "timestamp": true
  },
  "dns": {
    "servers": [
      {
        "type": "udp",
        "tag": "remote-dns",
        "server": "1.1.1.1",
        "server_port": 53,
        "detour": "{{ de_active }}"
      },
      {
        "type": "local",
        "tag": "local-dns"
      }
    ],
    "rules": [
      { "server": "remote-dns" }
    ],
    "strategy": "ipv4_only"
  },
  "inbounds": [
    {
      "type": "socks",
      "tag": "local-socks",
      "listen": "{{ ru_singbox_socks_bind }}",
      "listen_port": {{ ru_singbox_socks_port }}
    },
    {
      "type": "http",
      "tag": "local-http",
      "listen": "{{ ru_singbox_http_bind }}",
      "listen_port": {{ ru_singbox_http_port }}
    },
    {
      "type": "shadowsocks",
      "tag": "router-in",
      "listen": "0.0.0.0",
      "listen_port": {{ router_ss_port }},
      "method": "{{ router_ss_method }}",
      "password": "{{ router_ss_secret }}"
    },
    {
      "type": "hysteria2",
      "tag": "hy2-in",
      "listen": "0.0.0.0",
      "listen_port": {{ hy2_port }},
      "obfs": {
        "type": "salamander",
        "password": "{{ hy2_obfs_password }}"
      },
      "users": [
        { "name": "router", "password": "{{ hy2_password }}" }
      ],
      "tls": {
        "enabled": true,
        "alpn": ["h3"],
        "certificate_path": "/etc/letsencrypt/live/{{ domain }}/fullchain.pem",
        "key_path": "/etc/letsencrypt/live/{{ domain }}/privkey.pem"
      }
    },
    {
      "type": "shadowtls",
      "tag": "shadowtls-in",
      "listen": "0.0.0.0",
      "listen_port": {{ shadowtls_port }},
      "version": 3,
      "users": [
        { "name": "router", "password": "{{ shadowtls_password }}" }
      ],
      "handshake": {
        "server": "{{ shadowtls_handshake_server }}",
        "server_port": 443
      },
      "strict_mode": true,
      "detour": "shadowtls-ss-in"
    },
    {
      "type": "shadowsocks",
      "tag": "shadowtls-ss-in",
      "listen": "127.0.0.1",
      "network": "tcp",
      "method": "{{ shadowtls_ss_method }}",
      "password": "{{ shadowtls_ss_secret }}"
    },
{# home->edge leg: VLESS+Reality+gRPC на публичном :443 (whitelist/TCP-страховка
   к hy2; обоснование gRPC-mux/Reality/донора — в group_vars/all.yml). Локально:
   hy2-in/shadowtls-in НЕ трогаем (Reality добавляется, не заменяет), egress тот
   же — route ниже заворачивает vless-reality-in в активный edge→DE outbound. #}
    {
      "type": "vless",
      "tag": "vless-reality-in",
      "listen": "0.0.0.0",
      "listen_port": 443,
      "users": [
        { "uuid": "{{ reality_uuid }}" }
      ],
      "tls": {
        "enabled": true,
        "server_name": "{{ reality_donor_sni }}",
        "reality": {
          "enabled": true,
          "handshake": {
            "server": "{{ reality_donor_sni }}",
            "server_port": 443
          },
          "private_key": "{{ reality_private_key }}",
          "short_id": ["{{ reality_short_id }}"]
        }
      },
      "transport": {
        "type": "grpc",
        "service_name": "{{ reality_grpc_service_name }}"
      }
    }{% if ru_public_proxy_enable | bool %},
    {
      "type": "socks",
      "tag": "public-socks",
      "listen": "{{ ru_public_proxy_bind }}",
      "listen_port": {{ ru_public_proxy_socks_port }},
      "users": [
        {% for u in proxy_users %}
        {
          "username": "{{ u.name }}",
          "password": "{{ u.password }}"
        }{% if not loop.last %},{% endif %}
        {% endfor %}
      ]
    },
    {
      "type": "http",
      "tag": "public-http",
      "listen": "{{ ru_public_proxy_bind }}",
      "listen_port": {{ ru_public_proxy_http_port }},
      "users": [
        {% for u in proxy_users %}
        {
          "username": "{{ u.name }}",
          "password": "{{ u.password }}"
        }{% if not loop.last %},{% endif %}
        {% endfor %}
      ]
    }{% endif %}
  ],
  "outbounds": [
    {
      "type": "shadowtls",
      "tag": "de-shadowtls-tls",
      "server": "{{ hostvars[groups['de_vps'][0]].ansible_host | default(groups['de_vps'][0]) }}",
      "server_port": {{ de_shadowtls_port }},
      "version": 3,
      "password": "{{ de_shadowtls_password }}",
      "tls": {
        "enabled": true,
        "server_name": "{{ de_shadowtls_handshake_server }}"
      }
    },
    {
      "type": "shadowsocks",
      "tag": "de-shadowtls-ss",
      "method": "{{ de_shadowtls_ss_method }}",
      "password": "{{ de_shadowtls_ss_secret }}",
      "detour": "de-shadowtls-tls"{% if singbox_server_multiplex | bool %},
      "multiplex": {
        "enabled": true,
        "protocol": "h2mux",
        "padding": true
      }{% endif %}
    },
    {
      "type": "shadowsocks",
      "tag": "de-ss",
      "server": "{{ hostvars[groups['de_vps'][0]].ansible_host | default(groups['de_vps'][0]) }}",
      "server_port": {{ singbox_server_port }},
      "method": "{{ singbox_server_method }}",
      "password": "{{ singbox_server_password }}"{% if singbox_server_multiplex | bool %},
      "multiplex": {
        "enabled": true,
        "protocol": "h2mux",
        "padding": true
      }{% endif %}
    },
    {
      "type": "direct",
      "tag": "direct"
    }
  ],
  "route": {
    {% if ru_singbox_default_interface == "auto" %}
    "auto_detect_interface": true,
    {% else %}
    "default_interface": "{{ ru_singbox_default_interface }}",
    {% endif %}
    "final": "{{ de_active }}",
    "default_domain_resolver": {
      "server": "remote-dns"
    },
    "rules": [
      { "inbound": ["router-in", "hy2-in", "shadowtls-ss-in", "vless-reality-in"], "outbound": "{{ de_active }}" },
      {
        "ip_cidr": ["{{ hostvars[groups['de_vps'][0]].ansible_host | default(groups['de_vps'][0]) }}/32"],
        "outbound": "direct"
      },
      {
        "port": [{{ ssh_port }}],
        "outbound": "direct"
      }
    ]
  }
}
