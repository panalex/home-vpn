#!/bin/sh /etc/rc.common
# Managed by Ansible (owrt_mgmt) — reverse-SSH тоннель управления к гейтвею.
# procd супервизит и переподключает; ssh идёт через sing-box TUN (final: proxy).
START=99
USE_PROCD=1

start_service() {
    procd_open_instance
    procd_set_param command /usr/bin/ssh -N -T \
        -i /etc/mgmt-ssh/id_ed25519 \
        -o BatchMode=yes \
        -o StrictHostKeyChecking=accept-new \
        -o UserKnownHostsFile=/etc/mgmt-ssh/known_hosts \
        -o ExitOnForwardFailure=yes \
        -o ServerAliveInterval={{ mgmt_keepalive_interval }} \
        -o ServerAliveCountMax={{ mgmt_keepalive_count }} \
        -o ConnectTimeout=20 \
        -p {{ mgmt_gateway_ssh_port }} \
        -R 127.0.0.1:{{ mgmt_reverse_port }}:127.0.0.1:22 \
        {{ mgmt_user }}@{{ _gw_host }}
    # respawn: порог 3600с, пауза 5с между попытками, 0 = бесконечно.
    procd_set_param respawn 3600 5 0
    procd_set_param stderr 1
    procd_close_instance
}
