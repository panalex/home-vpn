#!/bin/sh
# DPI bypass: nftables NFQUEUE rules для nfqws
# Managed by Ansible — do not edit manually
# Вызывается OpenWrt firewall при каждом reload.
# Создаём отдельную таблицу dpi_bypass, чтобы не конфликтовать с fw4.

NFT=nft

# На boot модуль nft_queue может быть ещё не загружен, и autoload из контекста fw4
# не срабатывает — тогда строка с `queue num` молча отваливается (грузится только
# соседний `drop`), и трафик уходит мимо nfqws. Грузим модуль явно до добавления правил.
modprobe nft_queue 2>/dev/null

# Создать таблицу (no-op если уже существует), затем сбросить правила.
# flush table удаляет правила из цепочек, но сохраняет сами цепочки.
$NFT add table inet dpi_bypass 2>/dev/null
$NFT flush table inet dpi_bypass

# Создать цепочку с hook output; 2>/dev/null — no-op если уже существует
# (после flush table цепочка сохраняется, add chain вернёт ошибку — нормально).
$NFT add chain inet dpi_bypass output_dpi \
    '{ type filter hook output priority -1; policy accept; }' 2>/dev/null

# Убить QUIC (UDP/443) для bypass-трафика → браузер откатится на TCP.
# bypass flag в queue: при остановленном nfqws пакеты проходят без обработки.
$NFT add rule inet dpi_bypass output_dpi \
    'meta l4proto udp meta mark {{ nfqws_routing_mark }} udp dport 443 drop'

$NFT add rule inet dpi_bypass output_dpi \
    'meta l4proto tcp meta mark {{ nfqws_routing_mark }} tcp dport { 80, 443 } queue num {{ nfqws_queue_num }} bypass'

# --- Маршрутизация инжектируемых nfqws пакетов мимо тоннеля sing-box ---
# sing-box auto_route policy-routing'ом (ip rule pref ~9000) заворачивает ВЕСЬ
# локальный трафик (iif lo) в singtun0. Десинк-пакеты, которые nfqws шлёт через
# raw-сокет, помечены его fwmark (--dpi-desync-fwmark, default {{ nfqws_fwmark }}),
# но без явного ip rule они тоже утягиваются в TUN и дропаются strict_route →
# "rawsend: sendto: Operation not permitted". Добавляем правило ВЫШЕ sing-box
# (pref < 9000): трафик с этой меткой идёт в main-таблицу → напрямую в WAN.
ip rule del fwmark {{ nfqws_fwmark }}/{{ nfqws_fwmark }} lookup main pref 8000 2>/dev/null
ip rule add fwmark {{ nfqws_fwmark }}/{{ nfqws_fwmark }} lookup main pref 8000
