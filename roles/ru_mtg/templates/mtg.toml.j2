secret = "{{ mtg_secret_effective }}"
bind-to = "{{ mtg_bind_host }}:{{ mtg_bind_port }}"
concurrency = {{ mtg_concurrency }}
prefer-ip = "{{ mtg_prefer_ip }}"
public-ipv4 = "{{ mtg_public_ipv4 }}"
auto-update = false
allow-fallback-on-unknown-dc = false

# Active-probe fronting. Маскировка под золотой домен — ПАССИВНАЯ: клиент рекламирует
# SNI = домен из секрета ({{ mtg_faketls_domain }}), это и видит ТСПУ на реальном
# трафике. На active-probe к edge:443 mtg реверс-проксирует пробу на этот таргет.
# Таргет — ЛОКАЛЬНАЯ заглушка ru_fronting (127.0.0.1:{{ mtg_domain_fronting_port }}):
# firewall намеренно запирает uid mtg на localhost (nftables chain output: reject
# admin-prohibited на любой внешний коннект mtg), поэтому сходить за живым yandex-
# сертом mtg НЕ может — фронтить на реальный uniqr.pay.yandex.net = "no route to
# host"/"operation not permitted". Заглушка отдаёт валидный LE-серт edge (home12.ru):
# active-probe видит правдоподобный небольшой сайт, но не yandex-серт (принятый
# trade-off — см. docs/architecture.md). ip оставлен localhost явно; порт берётся из
# mtg_domain_fronting_port (= порт заглушки 8443) — переменная теперь реально
# используется, хардкод/расхождение устранены.
[domain-fronting]
ip = "127.0.0.1"
port = {{ mtg_domain_fronting_port }}

[network]
dns = "{{ mtg_dns }}"
proxies = ["{{ mtg_proxy_via_socks_uri }}"]
tcp-timeout = "15s"
idle-timeout = "1m"

[network.keep-alive]
disabled = false
idle = "15s"
interval = "15s"
count = 9
